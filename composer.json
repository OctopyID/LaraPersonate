{
    "name": "octopyid/laravel-impersonate",
    "description": "Login as a different user quickly",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Supian M",
            "email": "supianidz@octopy.dev"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "larastan/larastan": "*",
        "laravel/pint": "*",
        "nunomaduro/collision": "*",
        "orchestra/testbench": "*",
        "pestphp/pest": "*",
        "pestphp/pest-plugin-laravel": "*"
    },
    "autoload": {
        "psr-4": {
            "Octopy\\Impersonate\\": "src/"
        },
        "files": [
            "src/Helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Octopy\\Impersonate\\Tests\\": "tests/"
        }
    },
    "conflict": {
        "lab404/laravel-impersonate": "*"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Octopy\\Impersonate\\Providers\\ImpersonateServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "analyse": "vendor/bin/phpstan analyse",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
